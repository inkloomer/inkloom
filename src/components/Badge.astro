---
// InkLoom/src/components/Badge.astro
interface Props {
  variant?: 'primary' | 'warning' | 'success' | 'danger' | 'info' | 'outline';
}

const { variant = 'primary' } = Astro.props;

const colors = {
  primary: { bg: '#eff6ff', text: '#1d4ed8', border: '#bfdbfe' },
  warning: { bg: '#fffbeb', text: '#d97706', border: '#fde68a' },
  success: { bg: '#ecfdf5', text: '#059669', border: '#a7f3d0' },
  danger: { bg: '#fff1f2', text: '#e11d48', border: '#fecdd3' },
  info: { bg: '#f0fdfa', text: '#0d9488', border: '#99f6e4' },
  outline: { bg: 'transparent', text: 'var(--sl-color-text-muted)', border: 'var(--sl-color-hairline)' }
};

const theme = colors[variant] || colors.primary;
---
<span style={`display: inline-flex; align-items: center; padding: 2px 10px; border-radius: 9999px; font-size: 11px; font-weight: 500; background-color: ${theme.bg}; color: ${theme.text}; border: 1px solid ${theme.border}; line-height: 1.2; vertical-align: middle;`}>
  <slot />
</span>
