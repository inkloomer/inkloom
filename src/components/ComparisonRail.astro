---
// InkLoom/src/components/ComparisonRail.astro
interface Props {
  label: string;
}

const { label } = Astro.props;
---
<div class="table-row" style="display: flex; align-items: center; padding: 12px 6px; border-bottom: 1px dashed var(--sl-color-hairline); transition: all 0.2s; border-radius: 8px;">
  <div style="width: 130px; font-weight: bold; font-size: 13px; color: var(--sl-color-text); padding-right: 8px; flex-shrink: 0;">
    {label}
  </div>
  <div style="flex: 1; display: flex; gap: 12px; min-width: 0; align-items: center;">
    <div style="flex: 1; display: flex; justify-content: center; text-align: center; font-size: 12.5px; color: var(--sl-color-text);">
      <slot name="m1" />
    </div>
    <div style="flex: 1; display: flex; justify-content: center; text-align: center; font-size: 12.5px; color: var(--sl-color-text);">
      <slot name="m2" />
    </div>
    <div style="flex: 1; display: flex; justify-content: center; text-align: center; font-size: 12.5px; color: var(--sl-color-text);">
      <slot name="m3" />
    </div>
  </div>
</div>
