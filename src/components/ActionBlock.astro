---
// InkLoom/src/components/ActionBlock.astro
import MoneyBadge from './MoneyBadge.astro';

interface Props {
  label: string;
  money?: string;
  badge?: string;
  icon?: 'bribe' | 'receive' | 'gavel' | 'scale' | 'chat' | 'handshake' | 'brain' | 'eye-off' | 'shield-alert' | 'check' | 'help';
  class?: string;
}

const { label, money, badge, icon, class: className } = Astro.props;
---
<div class={`glow-capsule ${className || ''}`} style="margin-bottom: 8px; padding: 8px 12px; background-color: var(--sl-color-bg); border: 1px solid var(--sl-color-hairline); border-radius: 6px; display: flex; align-items: center; justify-content: space-between; gap: 8px; transition: all 0.25s;">
  <div style="font-size: 12px; color: var(--sl-color-text); font-weight: 500; display: flex; align-items: center; gap: 8px;">
    {/* Always-on diverse SVG icons inspired by Lucide */}
    {icon === 'bribe' && (
      <svg class="anim-float" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;">
        <rect width="20" height="12" x="2" y="6" rx="2"></rect>
        <circle cx="12" cy="12" r="2"></circle>
        <path d="M6 12h.01M18 12h.01"></path>
      </svg>
    )}
    {icon === 'receive' && (
      <svg class="anim-float" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;">
        <circle cx="8" cy="8" r="6"></circle>
        <path d="M18.09 10.37A6 6 0 1 1 10.34 18"></path>
        <path d="M7 6h1v4H7zm3.5 1.5h1V9h-1z"></path>
      </svg>
    )}
    {icon === 'gavel' && (
      <svg class="anim-swing" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#047857" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; transform-origin: 18px 18px;">
        <path d="m14 13-5-5 3-3 5 5z"></path>
        <path d="m3 21 6-6"></path>
        <path d="m16 16 5-5"></path>
        <path d="m2 14 2-2 3 3-2 2z"></path>
        <path d="M15 2H22V9"></path>
      </svg>
    )}
    {icon === 'scale' && (
      <svg class="anim-swing" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#0d9488" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; transform-origin: 12px 3px;">
        <path d="M16 16c0 2.2-1.8 4-4 4s-4-1.8-4-4"></path>
        <path d="M12 3v17"></path>
        <path d="M3 10h18"></path>
        <path d="M6 10c0-2.2 1.8-4 4-4"></path>
        <path d="M14 6c2.2 0 4 1.8 4 4"></path>
      </svg>
    )}
    {icon === 'chat' && (
      <svg class="anim-pulse" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
      </svg>
    )}
    {icon === 'handshake' && (
      <svg class="anim-pulse" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;">
        <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
        <circle cx="9" cy="7" r="4"></circle>
        <path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
        <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
      </svg>
    )}
    {icon === 'brain' && (
      <svg class="anim-pulse" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#7c3aed" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;">
        <path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96-.44 2.5 2.5 0 0 1 0-3.12 3 3 0 0 1 0-4.88 2.5 2.5 0 0 1 0-3.12A2.5 2.5 0 0 1 9.5 2Z"></path>
        <path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96-.44 2.5 2.5 0 0 0 0-3.12 3 3 0 0 0 0-4.88 2.5 2.5 0 0 0 0-3.12A2.5 2.5 0 0 0 14.5 2Z"></path>
      </svg>
    )}
    {icon === 'eye-off' && (
      <svg class="anim-shiver-gentle" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#64748b" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;">
        <path d="M9.88 9.88a3 3 0 1 0 4.24 4.24"></path>
        <path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68"></path>
        <path d="M6.61 6.61A13.52 13.52 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61"></path>
        <line x1="2" y1="2" x2="22" y2="22"></line>
      </svg>
    )}
    {icon === 'shield-alert' && (
      <svg class="anim-shiver-gentle" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
        <line x1="12" y1="8" x2="12" y2="12"></line>
        <line x1="12" y1="16" x2="12.01" y2="16"></line>
      </svg>
    )}
    {icon === 'check' && (
      <svg class="anim-pulse" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;">
        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
        <polyline points="22 4 12 14.01 9 11.01"></polyline>
      </svg>
    )}
    {icon === 'help' && (
      <svg class="anim-float" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;">
        <circle cx="12" cy="12" r="10"></circle>
        <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
        <line x1="12" y1="17" x2="12.01" y2="17"></line>
      </svg>
    )}
    {!icon && (
      <span style="width: 5px; height: 5px; background-color: var(--sl-color-text-muted); border-radius: 50%; display:inline-block; flex-shrink:0;"></span>
    )}
    
    <span style="line-height: 1.2;">{label}</span>
  </div>
  <div class="answer-node" style="display: flex; align-items: center; gap: 6px; flex-shrink: 0; border-radius: 4px; padding: 2px;">
    {money && <MoneyBadge amount={money} />}
    {badge && <span style="font-size: 10px; font-weight: bold; padding: 2px 6px; border-radius: 4px; background-color: var(--sl-color-accent-low); color: var(--sl-color-accent-high); border: 1px solid var(--sl-color-hairline);">{badge}</span>}
  </div>
</div>
