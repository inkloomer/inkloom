---
// InkLoom/src/components/CaseCard.astro
import Badge from './Badge.astro';

interface Props {
  title: string;
  subject?: string;
  year?: string;
}

const { title, subject, year } = Astro.props;
---
<div style="margin: 20px 0; background-color: var(--sl-color-bg); border: 1px solid var(--sl-color-hairline); border-radius: 12px; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05); display: flex; flexDirection: column; overflow: hidden; transition: all 0.3s;" class="interactive-card">
  {/* Header */}
  <div style="display: flex; align-items: center; gap: 12px; px: 16px; py: 12px; padding: 12px 16px; background-color: var(--sl-color-bg-sidebar); border-bottom: 1px solid var(--sl-color-hairline);">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--sl-color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--sl-color-accent);"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1-2.5-2.5Z"></path><path d="M6 6h10"></path><path d="M6 10h10"></path></svg>
    <span style="font-weight: 600; font-size: 15px; color: var(--sl-color-text); flex: 1;">
      {title}
    </span>
    <div style="display: flex; align-items: center; gap: 8px;">
      {subject && <Badge variant="primary">{subject}</Badge>}
      {year && <Badge variant="outline">{year}</Badge>}
    </div>
  </div>
  {/* Body */}
  <div style="padding: 16px; font-size: 14.5px; lineHeight: 1.6; color: var(--sl-color-text);">
    <slot />
  </div>
</div>
