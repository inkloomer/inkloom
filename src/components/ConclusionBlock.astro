---
// InkLoom/src/components/ConclusionBlock.astro
interface Props {
  type: '想象竞合' | '牵连犯' | '独立既遂' | '不构成犯罪' | '共犯既遂';
  label: string;
}

const { type, label } = Astro.props;

const config = {
  想象竞合: { bg: '#f5f3ff', border: '#ddd6fe', text: '#6d28d9', icon: '⚖️' },
  牵连犯: { bg: '#fff7ed', border: '#ffedd5', text: '#c2410c', icon: '🔗' },
  独立既遂: { bg: '#ecfdf5', border: '#a7f3d0', text: '#047857', icon: '✓' },
  共犯既遂: { bg: '#f0fdfa', border: '#99f6e4', text: '#0d9488', icon: '👥' },
  不构成犯罪: { bg: '#fef2f2', border: '#fecdd3', text: '#be123c', icon: '✗' }
};

const theme = config[type] || config.独立既遂;
---
<div class="glow-capsule answer-node" style={`margin-top: 10px; padding: 10px 12px; background-color: ${theme.bg}; border: 1px solid ${theme.border}; border-radius: 8px; color: ${theme.text}; font-size: 12px; font-weight: bold; display: flex; align-items: center; gap: 8px; transition: all 0.25s;`}>
  <span style="font-size: 14px; line-height: 1;">{theme.icon}</span>
  <span style="line-height: 1.2;">{type}：{label}</span>
</div>
